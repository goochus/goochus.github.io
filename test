<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sway Nightclub — BoldPage</title>
  <meta name="description" content="Sway Nightclub is a Miami nightlife spot known for late nights, a strong atmosphere, and easy access to official links, directions, and contact details." />
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">

  <style>
    :root {
      --bg: #050505;
      --bg-soft: #0c0c0c;
      --panel: #121212;
      --panel-2: #181818;
      --line: rgba(255, 255, 255, .06);
      --line-soft: rgba(255, 255, 255, .03);
      --text: #fdfdfd;
      --muted: #a1a1aa;
      --yellow: #f0dc42;
      --yellow-glow: rgba(240, 220, 66, 0.15);
      --shadow: 0 20px 40px rgba(0,0,0,0.4);
      --radius: 28px;
      --max: 1220px;
      --ease: cubic-bezier(0.23, 1, 0.32, 1); /* High-end easing */
    }

    * { box-sizing: border-box; }

    /* Custom Scrollbar */
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: #333; border-radius: 10px; }
    ::-webkit-scrollbar-thumb:hover { background: #444; }

    html { scroll-behavior: smooth; }

    body {
      margin: 0; padding: 0;
      background-color: var(--bg);
      color: var(--text);
      font-family: 'Inter', sans-serif;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* Subtle Noise Texture Overlay */
    body::before {
      content: "";
      position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
      background-image: url("https://grainy-gradients.vercel.app/noise.svg");
      opacity: 0.22; pointer-events: none; z-index: 50; contrast: 120%;
    }

    .wrap { width: min(calc(100% - 40px), var(--max)); margin: 0 auto; }

    /* --- Animations --- */
    .reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.8s var(--ease), transform 0.8s var(--ease);
    }
    .reveal.active {
      opacity: 1;
      transform: translateY(0);
    }

    /* --- Header --- */
    .site-header {
      position: sticky; top: 0; z-index: 100;
      backdrop-filter: blur(20px);
      background: rgba(5, 5, 5, 0.8);
      border-bottom: 1px solid var(--line);
      transition: all 0.4s var(--ease);
    }
    .site-header .inner {
      min-height: 80px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .brand { display: flex; align-items: center; gap: 12px; font-weight: 900; }
    .brand-mark {
      min-width: 66px; height: 42px;
      display: inline-flex; align-items: center; justify-content: center;
      border-radius: 12px; background: var(--yellow); color: #000;
      box-shadow: 0 0 20px var(--yellow-glow);
      font-size: 1rem; transition: transform 0.3s var(--ease);
    }
    .brand:hover .brand-mark { transform: scale(1.05) rotate(-2deg); }
    .brand-type { text-transform: uppercase; letter-spacing: .2em; font-size: .9rem; }

    .top-btn {
      min-height: 44px; padding: 0 20px; border-radius: 12px; border: 1px solid var(--line);
      background: rgba(255,255,255,0.03); font-weight: 600;
      transition: all 0.3s var(--ease);
    }
    .top-btn:hover { background: #fff; color: #000; transform: translateY(-2px); }

    /* --- Hero Section --- */
    .hero { padding: 60px 0 40px; }
    .hero-shell { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 30px; }

    .copy-panel {
      min-height: 680px;
      display: flex; flex-direction: column; justify-content: flex-end;
      padding: 50px; border-radius: var(--radius);
      background: linear-gradient(160deg, #111 0%, #080808 100%);
      border: 1px solid var(--line);
      position: relative; overflow: hidden;
    }

    h1 {
      margin: 0; font-size: clamp(3.5rem, 6vw, 6.5rem);
      line-height: 0.9; letter-spacing: -0.05em; font-weight: 800;
      background: linear-gradient(to bottom, #fff 60%, #888);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }

    .descriptor { margin: 24px 0; font-size: 1.15rem; color: var(--muted); max-width: 500px; line-height: 1.6; }

    .actions { display: flex; gap: 12px; margin-top: 30px; }
    .btn {
      min-height: 56px; padding: 0 28px; border-radius: 16px; 
      display: inline-flex; align-items: center; justify-content: center;
      font-weight: 700; border: 1px solid var(--line); background: var(--panel-2);
      transition: all 0.3s var(--ease); cursor: pointer;
    }
    .btn.primary { background: var(--yellow); color: #000; border: none; }
    .btn.primary:hover { transform: scale(1.03); box-shadow: 0 10px 30px var(--yellow-glow); }
    .btn:not(.primary):hover { background: #222; border-color: #444; }

    .image-panel {
      border-radius: var(--radius); overflow: hidden; position: relative;
      border: 1px solid var(--line); height: 100%;
    }
    .image-panel img {
      width: 100%; height: 100%; object-fit: cover;
      transition: transform 1.2s var(--ease);
    }
    .image-panel:hover img { transform: scale(1.1); }

    /* --- Content Grid --- */
    .content-grid { display: grid; grid-template-columns: 1fr 360px; gap: 30px; padding-bottom: 100px; }
    
    .card {
      background: var(--bg-soft); border: 1px solid var(--line);
      border-radius: var(--radius); transition: all 0.4s var(--ease);
      position: relative;
    }
    .card:hover { border-color: rgba(255,255,255,0.15); transform: translateY(-4px); }

    .card-inner { padding: 40px; }
    .title { font-size: 1.6rem; font-weight: 800; margin-bottom: 10px; }
    .overview { font-size: 1.1rem; line-height: 1.8; color: #ccc; }
    .overview strong { color: var(--yellow); font-weight: 600; }

    /* --- Bold Take --- */
    .bold-take {
      background: linear-gradient(90deg, rgba(240,220,66,0.08), transparent);
      border-left: 3px solid var(--yellow); padding: 25px; border-radius: 0 20px 20px 0;
    }

    /* --- Highlights --- */
    .service-grid {
      display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px;
      list-style: none; padding: 0;
    }
    .service-grid li {
      background: rgba(255,255,255,0.03); border: 1px solid var(--line);
      padding: 18px; border-radius: 18px; font-weight: 600;
      transition: 0.3s var(--ease);
    }
    .service-grid li:hover { background: rgba(255,255,255,0.06); transform: translateX(5px); }

    /* --- Sidebar --- */
    .mini {
      background: var(--bg-soft); border: 1px solid var(--line);
      border-radius: 24px; padding: 24px; margin-bottom: 24px;
    }
    .row {
      background: rgba(255,255,255,0.02); border: 1px solid var(--line);
      border-radius: 16px; padding: 16px; margin-bottom: 12px;
      transition: 0.3s;
    }
    .row:hover { background: rgba(255,255,255,0.05); }
    .row .k { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 4px; }
    .row .v { font-weight: 700; color: #fff; }

    @media (max-width: 1020px) {
      .hero-shell, .content-grid { grid-template-columns: 1fr; }
      .copy-panel { min-height: 500px; padding: 30px; }
      .image-panel { height: 400px; }
    }
  </style>
</head>
<body>

  <header class="site-header">
    <div class="wrap inner">
      <a class="brand" href="#">
        <span class="brand-mark">BOLD</span>
        <span class="brand-type">PAGE</span>
      </a>
      <a class="top-btn" href="#">Request Page</a>
    </div>
  </header>

  <main>
    <section class="hero wrap">
      <div class="hero-shell">
        <div class="copy-panel reveal">
          <div style="margin-bottom: 20px; display: inline-flex; align-items: center; gap: 8px; font-size: 0.8rem; font-weight: 700; color: var(--yellow);">
            <span style="width: 8px; height: 8px; background: var(--yellow); border-radius: 50%; box-shadow: 0 0 10px var(--yellow);"></span>
            FEATURED PROFILE
          </div>
          <h1>Sway Nightclub</h1>
          <p class="descriptor">The definitive Miami nightlife experience. Late nights, high energy, and unparalleled vibes in the heart of the city.</p>
          <div class="actions">
            <a class="btn primary">Official Website</a>
            <a class="btn">Get Directions</a>
          </div>
        </div>

        <div class="image-panel reveal" style="transition-delay: 0.2s;">
          <img src="https://images.unsplash.com/photo-1566737236500-c8ac43014a8e?auto=format&fit=crop&w=1200&q=80" alt="Club Atmosphere">
        </div>
      </div>
    </section>

    <section class="content wrap">
      <div class="content-grid">
        <div class="stack" style="display: flex; flex-direction: column; gap: 30px;">
          
          <section class="card reveal">
            <div class="card-inner">
              <h3 class="title">The Overview</h3>
              <p class="overview">
                <strong>Sway Nightclub</strong> stands as a pillar of Miami's legendary nightlife scene. This BoldPage profile serves as the official digital gateway for guests seeking a polished, direct connection to the venue's services, timing, and reservations.
              </p>
            </div>
          </section>

          <section class="card reveal">
            <div class="card-inner">
              <h3 class="title">The Bold Take</h3>
              <div class="bold-take">
                <p style="margin: 0; line-height: 1.6; font-style: italic;">
                  "A sharp, no-nonsense destination for those who value atmosphere over noise. It’s the vibe you check before you head out."
                </p>
              </div>
            </div>
          </section>

          <section class="card reveal">
            <div class="card-inner">
              <h3 class="title">Service Highlights</h3>
              <ul class="service-grid">
                <li>VIP Table Service</li>
                <li>Express Guestlist</li>
                <li>Curated DJ Lineups</li>
                <li>Prime Miami Location</li>
                <li>Elite Sound Systems</li>
                <li>Private Event Booking</li>
              </ul>
            </div>
          </section>
        </div>

        <aside class="side">
          <div class="mini reveal">
            <h3 style="font-size: 1.1rem; margin-top: 0;">Business Info</h3>
            <div class="row">
              <div class="k">Phone</div>
              <div class="v">(305) 555-0111</div>
            </div>
            <div class="row">
              <div class="k">Location</div>
              <div class="v">111 Example Ave, Miami, FL</div>
            </div>
            <div class="row">
              <div class="k">Hours</div>
              <div class="v">Thu — Sun, 11PM - 4AM</div>
            </div>
            <p style="font-size: 0.75rem; color: var(--muted); margin: 20px 0 0;">Last verified: April 2026</p>
          </div>

          <div class="mini reveal" style="background: var(--yellow); color: #000;">
            <p style="margin: 0; font-weight: 800; font-size: 0.9rem;">BOLD TIP:</p>
            <p style="margin: 5px 0 0; font-size: 0.85rem; line-height: 1.4;">Arrive before midnight on Fridays to avoid the primary rush at the door.</p>
          </div>
        </aside>
      </div>
    </section>
  </main>

  <script>
    // Reveal animations on scroll
    const observerOptions = {
      threshold: 0.1,
      rootMargin: "0px 0px -50px 0px"
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, observerOptions);

    document.querySelectorAll('.reveal').forEach(el => {
      observer.observe(el);
    });

    // Subtle header shrink on scroll
    window.addEventListener('scroll', () => {
      const header = document.querySelector('.site-header');
      if (window.scrollY > 50) {
        header.style.padding = '5px 0';
        header.style.background = 'rgba(5, 5, 5, 0.95)';
      } else {
        header.style.padding = '0';
        header.style.background = 'rgba(5, 5, 5, 0.8)';
      }
    });
  </script>
</body>
</html>
