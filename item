    return items.filter(function (item) {
      return item.active !== false;
    });
  }

  function byFeatured(a, b) {
    return (a.featured || 9999) - (b.featured || 9999);
  }

  function normalizeLane(lane) {
    if (!lane) return "";
    return String(lane).toLowerCase().trim();
  }

  function getAllItems() {
    return activeOnly(PHYSICAL_ITEMS.concat(DIGITAL_ITEMS)).sort(byFeatured);
  }

  function getPhysicalItems() {
    return activeOnly(PHYSICAL_ITEMS).sort(byFeatured);
  }

  function getDigitalItems() {
    return activeOnly(DIGITAL_ITEMS).sort(byFeatured);
  }

  function findItem(id, lane) {
    const normalizedLane = normalizeLane(lane);
    const allItems = getAllItems();

    return allItems.find(function (item) {
      if (normalizedLane) {
        return item.id === id && item.lane === normalizedLane;
      }

      return item.id === id;
    }) || null;
  }

  function getRelatedItems(item, limit) {
    if (!item) return [];

    const max = typeof limit === "number" ? limit : 4;
    const sameLane = getAllItems().filter(function (candidate) {
      return candidate.id !== item.id && candidate.lane === item.lane;
    });

    const related = sameLane.filter(function (candidate) {
      return candidate.category === item.category || candidate.format === item.format;
    });

    const fallback = sameLane.filter(function (candidate) {
      return !related.some(function (rel) {
        return rel.id === candidate.id;
      });
    });

    return related.concat(fallback).slice(0, max);
  }

  function itemToCartLine(item, quantity) {
    const qty = Math.max(1, Number(quantity) || 1);

    return {
      id: item.id,
      lane: item.lane,
      name: item.name,
      unit_price: item.price,
      quantity: qty,
      line_total: item.price * qty
    };
  }

